model User {
    id  String @id @default(uuid())
    name String
    email String @unique
    password String 
    phone String?
    address String?
    profilePhoto String?

    role  Role @default(USER)
   status        UserStatus  @default(ACTIVE)
    isDeleted     Boolean  @default(false)
  deletedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt




  userId 
}